# Copy this file to `.env` and fill in ONE of the options below.
# With no key at all, the agent still runs using its deterministic rule-based
# brain — so this is entirely optional.
#
# The agent picks a brain in this order:  FREE provider  ->  Anthropic  ->  rules


# ============================================================================
# OPTION A — FREE LLM  (recommended; no credit card needed)
# ============================================================================
# Works with any OpenAI-compatible provider. Two good free ones:
#
# --- Groq (free, very fast) -------------------------------------------------
#   1. Sign up at https://console.groq.com  (no card)
#   2. Create an API key, paste it below.
# LLM_API_KEY=gsk_...
# LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM_MODEL=llama-3.3-70b-versatile
#
# --- Google Gemini (free) ---------------------------------------------------
#   1. Get a key at https://aistudio.google.com/app/apikey  (no card)
#   2. Paste it below.
# LLM_API_KEY=AIza...
# LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# LLM_MODEL=gemini-2.0-flash


# ============================================================================
# OPTION B — Anthropic / Claude  (paid, separate from any chat subscription)
# ============================================================================
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-opus-4-8
